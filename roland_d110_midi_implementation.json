    },
    "mode_messages": {
      "all_notes_off": {
        "status_range": "B0h-BFh",
        "second_byte": "7Bh",
        "third_byte": "00h",
        "midi_channel": "MIDI Channel",
        "description": "Turns off all notes that have been turned on by MIDI Note on"
      },
      "omni_off": {
        "status_range": "B0h-BFh", 
        "second_byte": "7Ch",
        "third_byte": "00h",
