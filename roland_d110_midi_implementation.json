      "description": "In Overflow event mode, retransmits the following MIDI 1A messages",
      "note_on": "Channel voice messages except Note on",
      "note_off": "Note on messages in which the assigned octave output's because note on messages to which the assigned octave 1 - 110 are simultaneously assignable voices."
    },
    "exclusive_messages": {
      "status": {
        "foo": "System Exclusive",
        "f7h": "End of Exclusive"
      },
      "patch_mode": "When in Patch or Timbre Select mode, a Patch is set of parameters constitutes a timbre can be transmitted",
      "multimode": "Individual parameter can be sent while editing",
      "bulk_dump": "Timbre data can be transmitted when Exclusive Messages"
    }
  },
  "recognized_receive_data": {
    "note_events": {
      "note_off": {
        "status_range": "80h-8Fh",
        "second_byte": "00h-7Fh (note number)",
        "third_byte": "ignored",
        "description": "Note off message"
      },
      "note_on": {
        "status_range": "90h-9Fh", 
        "second_byte": "00h-7Fh (note number)",
        "third_byte": "01h-7Fh (velocity)",
        "description": "Note on message",
        "notes": "Note numbers outside of the range 12-108 are transposed to the nearest octave inside the range. For note off, 7-110 remains in mode 3 (Omni Off, Poly)."
      }
    },
    "control_change": {
      "modulation_depth": {
        "status_range": "B0h-BFh",
        "second_byte": "01h",
        "third_byte": "00h-7Fh (modulation depth)",
        "midi_channel": "MIDI Channel"
      },
      "data_entry": {
        "status_range": "B0h-BFh", 
        "second_byte": "06h",
        "third_byte": "00h-7Fh (value of a parameter specified by RPC)",
        "midi_channel": "MIDI Channel"
      },
      "main_volume": {
        "status_range": "B0h-BFh",
        "second_byte": "07h", 
        "third_byte": "00h-7Fh (main volume)",
        "midi_channel": "MIDI Channel",
        "description": "Controls the volume of a Part accessible through the received MIDI channel. The maximum volume is determined by OUTPUT LEVEL set on the panel and bias volume message."
      },
      "expression": {
        "status_range": "B0h-BFh",
        "second_byte": "0Bh",
        "third_byte": "00h-7Fh (expression)",
        "midi_channel": "MIDI Channel",
        "description": "Can control the volume of the playing midi. The maximum volume is determined by OUTPUT LEVEL set on the panel and Main volume message."
      },
      "hold1": {
        "status_range": "B0h-BFh",
        "second_byte": "40h",
        "third_byte": "00h-3Fh (OFF), 40h-7Fh (ON)",
        "midi_channel": "MIDI Channel"
      },
      "rpc_lsb": {
        "status_range": "B0h-BFh",
        "second_byte": "64h",
        "third_byte": "00h-7Fh (lower byte of a parameter number controlled by RPC)",
        "midi_channel": "MIDI Channel"
      },
      "rpc_msb": {
        "status_range": "B0h-BFh", 
        "second_byte": "65h",
        "third_byte": "00h-7Fh (upper byte of a parameter number controlled by RPC)",
        "midi_channel": "MIDI Channel",
        "description": "Only PITCH BEND of #110 parameters can be controlled in Control change events PITCH Ch and the parameter to be controlled. Effective only while an F0 or F7 is not reached."
      },
      "reset_all_controllers": {
        "status_range": "B0h-BFh",
        "second_byte": "79h", 
        "third_byte": "00h",
        "midi_channel": "MIDI Channel"
      }
    },
    "program_change": {
      "patch_timbre_change": {
        "status_range": "C0h-CFh",
        "second_byte": "00h-7Fh (patch number)",
        "midi_channel": "MIDI Channel",
        "description": "Program change information on the control channel changes patches. If the sound accompanies program numbers 60h-7Fh is not available, it Performs the display shows"
      }
    },
    "pitch_bender_change": {
      "status_range": "E0h-EFh",
      "second_byte": "00h-7Fh (pitch bender change value)",
      "third_byte": "00h-7Fh",
