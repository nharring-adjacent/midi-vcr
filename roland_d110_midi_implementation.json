    "exclusive_messages": {
      "status": {
        "f0h": "System Exclusive",
        "f7h": "End of Exclusive"
      },
      "description": "Using exclusive message, a set of parameters for a Patch (timbre) or individual parameter can be set as a set data Timbre transmitted to/from a host. Currently message can be exchange. Refer to Roland Exclusive Messages and Sections 4 and 5."
    },
    "active_sensing": {
      "status": "FEh",
      "description": "Active Sensing. When received this message, D-110 expects to receive information of the same. Within 300msec. If D-110 fails to check messages within this time, all notes turn off. Currently message doesn't request."
    }
  },
  "exclusive_communication": {
    "description": "Parameters for patches, timbre or tones can be transferred to/from Roland devices in blocks: patches, timbre, tone, systems. Model IDs of device using these one MIDI channel as assigned to D-110. Only patches with the control ID of the D-110 can transfer parameters with D-110 devices. Since devices can be paired with additional parameter transfer. MIDI channel assignments remain, transfers. To use MIDI channel as described by Channel Mode. Separate parameters using the address in the transmitted. MIDI channel number or Unit #.",
    "one_way_communication": {
      "request_data": {
        "format": "F0H 41H <device ID> 11H <address> <size> <checksum> F7H",
        "description": "Request data"
      },
      "data_set_1": {
        "format": "F0H 41H <device ID> 12H <address> <data> <checksum> F7H", 
        "description": "Data set 1"
      }
    },
    "handshaking_communications": {
      "want_to_send_data": {
        "format": "F0H 41H <device ID> 40H <data> F7H",
        "description": "Want to send data"
      },
      "request_data": {
        "format": "F0H 41H <device ID> 41H <data> F7H",
        "description": "Request data"  
      },
      "data_set_1": {
        "format": "F0H 41H <device ID> 42H <data> F7H",
        "description": "Data set 1"
      },
      "acknowledge": {
        "format": "F0H 41H <device ID> 43H <data> F7H",
        "description": "Acknowledge"
      },
      "end_of_data": {
        "format": "F0H 41H <device ID> 45H <data> F7H", 
        "description": "End of data"
      },
      "communication_error": {
        "format": "F0H 41H <device ID> 4EH <data> F7H",
        "description": "Communication error"
      },
      "rejection": {
        "format": "F0H 41H <device ID> 4FH <data> F7H",
        "description": "Rejection"
      }
    },
    "starting_sequences": {
      "transmitter_initiating": "D-110 sends parameters using one appropriate events. D-110 sends parameters to the external unit matching to the device ID in the transmitted messages upon receiving this message",
      "receiver_initiating": "D-110 accepts received data from external synthesizer units that send D-110 as base parameters from D-110",
      "address_matching": "If the address matches to parameters have address, stops parameters receives from external. Otherwise sends this message.",
      "failure_response": "Should failure to data occur, disconnect of checksum, sends the previous data again."
    }
  },
